# URL do site em HTTPS para o app Capacitor (WebView remota). Sem barra final.
# Ex.: https://app.teudominio.com — tem de coincidir com onde o front está servido.
# O ficheiro capacitor.config.json é gerado por: npm run mobile:config
CAPACITOR_SERVER_URL=

# URL da API (quando não usar proxy no dev)
VITE_API_URL=http://localhost:3001/api
# Alvo do proxy no dev (backend); use 127.0.0.1 se localhost der ENOBUFS
# VITE_API_TARGET=http://127.0.0.1:3001

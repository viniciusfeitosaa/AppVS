# ============================================
# CONFIGURAÇÕES DO BACKEND
# ============================================

# Servidor
PORT=3001
NODE_ENV=development

# ============================================
# BANCO DE DADOS (EXTERNO - VPS)
# ============================================
# IMPORTANTE: O banco de dados roda FORA do container Docker
# Configure o IP/hostname da sua VPS onde o PostgreSQL está instalado

DATABASE_URL=postgresql://usuario:senha@IP_VPS:5432/app_medico
DB_HOST=IP_OU_HOSTNAME_VPS
DB_PORT=5432
DB_NAME=app_medico
DB_USER=app_medico_user
DB_PASSWORD=senha_super_segura_aqui

# ============================================
# AUTENTICAÇÃO JWT
# ============================================
# IMPORTANTE: Use chaves aleatórias e seguras em produção
# Gere com: openssl rand -base64 32

JWT_SECRET=sua_chave_jwt_super_secreta_aqui
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=sua_chave_refresh_super_secreta_aqui
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# SEGURANÇA
# ============================================

# Bcrypt rounds (recomendado: 12+)
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS
# ============================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://seu-dominio.com

# HTTPS (staging / antes do domínio final)
# - Só mudar para https:// aqui depois que o navegador já abrir o site em HTTPS.
# - Ajuste em conjunto: FRONTEND_URL, ALLOWED_ORIGINS e VITE_API_URL (mesmo esquema/host).
# - Certificado Let’s Encrypt exige um NOME (domínio ou subdomínio), não costuma funcionar com IP puro.
# - Ex.: subdomínio provisório: app-staging.suaempresa.com.br → Nginx/Caddy (443) → containers.
# - Alternativas rápidas: Cloudflare Tunnel, ngrok, Tailscale Funnel (HTTPS sem montar cert na VPS).

# ============================================
# SEED (utilizador master inicial) — necessário para primeiro login
# ============================================
# Depois de definir, rode na VPS: docker compose run --rm backend npx prisma db seed
MASTER_INITIAL_PASSWORD=defina_uma_senha_forte_com_pelo_menos_8_caracteres
# Opcional (predefinição no código se omitido):
# MASTER_INITIAL_EMAIL=contato@sejavivasaude.com.br
# TENANT_DEFAULT_SLUG=seja-viva-saude

# ============================================
# FRONTEND (build Docker / Vite) — OBRIGATÓRIO na VPS
# ============================================
# URL que o NAVEGADOR usa para chamar a API (não use localhost salvo em dev no mesmo PC).
# Ex.: http://IP:3001/api ou https://api.teudominio.com/api
# Tem de bater com ALLOWED_ORIGINS / FRONTEND_URL no backend.
# Se o site for servido em HTTPS, use https:// na API também (evita mixed content e ajuda câmera/geolocalização).
VITE_API_URL=http://SEU_IP_OU_DOMINIO:3001/api
# Docker: o build define VITE_APP_BASE=/app/ no Dockerfile — site público em http://IP:8082/ , app em http://IP:8082/app/

# ============================================
# CONFIGURAÇÕES DO FRONTEND (legado / outros)
# ============================================
REACT_APP_API_URL=http://localhost:3001
REACT_APP_ENV=development

# ============================================
# NGINX (se necessário)
# ============================================
NGINX_PORT=80
NGINX_SSL_PORT=443

# ============================================
# MONITORAMENTO (opcional)
# ============================================
# SENTRY_DSN=
# LOG_LEVEL=info

# ============================================
# DOCUSEAL (opcional — assinaturas)
# ============================================
# Instância própria (recomendado): URL público + token da API (Definições → API no DocuSeal).
# DOCUSEAL_URL=https://assinaturas.exemplo.com
# DOCUSEAL_API_KEY=...
# Dois (ou mais) modelos: array JSON — id/name iguais ao DocuSeal; role do médico costuma ser "Primeira Parte".
# DOCUSEAL_REQUIRED_TEMPLATES=[{"id":1,"name":"Contrato A","role":"Primeira Parte"},{"id":2,"name":"Contrato B","role":"Primeira Parte"}]
# DOCUSEAL_SECOND_SUBMITTER_EMAIL=segunda@exemplo.com
# Cloud DocuSeal (SaaS): DOCUSEAL_API_BASE_URL=https://api.docuseal.com + DOCUSEAL_API_TOKEN=...
